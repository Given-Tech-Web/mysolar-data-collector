{
  "name": "solar-data-collector",
  "version": "1.0.0",
  "description": "HiveMQ Cloud to MariaDB data collection and processing system for solar monitoring",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "migrate": "tsx src/database/migrate.ts",
    "setup-procedures": "tsx scripts/setup-procedures.ts",
    "create-processing-log": "tsx scripts/create-processing-log.ts",
    "fix-db-issues": "tsx scripts/fix-db-issues.ts",
    "test-db": "tsx scripts/test-db-connection.ts",
    "app:status": "bash scripts/manage-app.sh status",
    "app:stop": "bash scripts/stop-app.sh",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "mqtt": "^5.10.1",
    "mysql2": "^3.11.4",
    "dotenv": "^16.4.7",
    "winston": "^3.17.0",
    "node-cron": "^3.0.3",
    "dayjs": "^1.11.13",
    "joi": "^17.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  }
}